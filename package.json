{
  "name": "dash",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild-file-preview.cjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --force"
  },
  "dependencies": {
    "echarts": "^5.6.0",
    "echarts-gl": "^2.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.0.0"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "semi": false,
    "trailingComma": "none",
    "endOfLine": "lf"
  }
}
